{
  "name": "home-book-store",
  "version": "0.1.0",
  "description": "Private desktop home library importer",
  "license": "MIT",
  "author": "yc",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "desktop": "electron .",
    "build": "next build",
    "pack": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:win:arm64": "npm run build && electron-builder --win nsis --arm64",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "build": {
    "appId": "local.home-book-store",
    "productName": "Home Book Store",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "!.next/cache/**/*",
      "!.next/dev/**/*",
      "!.next/diagnostics/**/*",
      "!.next/types/**/*",
      "!.next/trace",
      "!.next/trace-build",
      "!.next/turbopack/**/*",
      "!.next/**/*.nft.json",
      "!.next/**/*.map",
      "electron/**/*",
      "public/**/*",
      "!public/uploads/**/*",
      "next.config.ts",
      "package.json",
      "!src/**/*",
      "!.data/**/*",
      "!coverage/**/*",
      "!test-results/**/*",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.d.mts",
      "!node_modules/**/*.d.cts",
      "!node_modules/**/*.map",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/__tests__/**/*",
      "!**/.DS_Store"
    ],
    "mac": {
      "target": "dmg",
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
